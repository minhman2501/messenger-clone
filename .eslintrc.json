{
    "extends": [
        "eslint:recommended",
        "next/core-web-vitals",
        "prettier",
        "plugin:@typescript-eslint/recommended",
        "plugin:@typescript-eslint/recommended-requiring-type-checking"
    ],
    "parserOptions": {
        "sourceType": "module",
        "project": "./tsconfig.json"
    },
    "plugins": ["prettier", "tailwindcss"],
    "parser": "@typescript-eslint/parser",
    "rules": {
        "prettier/prettier": [
            "warn",
            {
                "tabWidth": 4,
                "semi": false,
                "printWidth": 100,
                "trailingComma": "es5",
                "singleQuote": true,
                "jsxSingleQuote": true
            }
        ]
    }
}
